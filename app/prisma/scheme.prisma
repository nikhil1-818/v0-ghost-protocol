generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asset {
  id            String   @id @default(cuid())
  type          String
  model         String
  serial        String   @unique
  status        String
  location      String
  pickupDate    String?
  completedDate String?
  materials     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
